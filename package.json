{
  "name": "torcidaclub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check",
    "clean": "node -e \"['node_modules/.cache','.next','out'].forEach(f=>require('fs').rmSync(f,{recursive:true,force:true}))\"",
    "clean:full": "node -e \"['node_modules/.cache','.next','.next.corrupted','tsconfig.tsbuildinfo'].forEach(f=>require('fs').rmSync(f,{recursive:true,force:true}))\"",
    "fresh": "npm run clean:full && npm install && npm run dev",
    "troubleshoot": "npm run clean:full && npm cache clean --force && npm install && npm run dev",
    "clean:install": "node -e \"['node_modules','package-lock.json'].forEach(f=>require('fs').rmSync(f,{recursive:true,force:true}))\" && npm cache clean --force && npm install",
    "dev:clean": "npm run clean && npm run dev",
    "precommit": "npm run lint && npm run type-check",
    "prepare": "husky",
    "seed:mock": "tsx scripts/seed-mock-torcida.ts",
    "seed:clean-mock": "tsx scripts/clean-mock-torcida.ts",
    "seed:verify": "tsx scripts/verify-mock-torcida.ts",
    "seed:fix-mock": "tsx scripts/fix-mock-torcida.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.74.0",
    "@types/crypto-js": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.545.0",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.64.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.4.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-signature-canvas": "^1.0.7",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "husky": "^9.1.7",
    "jszip": "^3.10.1",
    "next": "^15.5.4",
    "postcss": "^8.4.49",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
