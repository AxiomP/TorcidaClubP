# ASAAS - Gateway de Pagamento (SANDBOX - homologação)
ASAAS_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=sua_api_key_asaas_sandbox
ASAAS_SUBSCRIPTION_VALUE=39.90
ASAAS_WEBHOOK_TOKEN=seu_token_webhook_asaas

# Ambiente
NODE_ENV=development